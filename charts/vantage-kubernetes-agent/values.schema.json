{
    "$schema": "http://json-schema.org/schema#",
    "type": "object",
    "properties": {
        "affinity": {
            "type": "object"
        },
        "agent": {
            "type": "object",
            "properties": {
                "allowedAnnotations": {
                    "type": "string"
                },
                "allowedLabels": {
                    "type": "string"
                },
                "argocdRollouts": {
                    "type": "boolean"
                },
                "clusterID": {
                    "type": "string"
                },
                "collectNamespaceLabels": {
                    "type": "string"
                },
                "collectPVCLabels": {
                    "type": "string"
                },
                "debug": {
                    "type": "boolean"
                },
                "disableKubeTLSverify": {
                    "type": "boolean"
                },
                "gpu": {
                    "type": "object",
                    "properties": {
                        "exporterNamespace": {
                            "type": "string"
                        },
                        "exporterPath": {
                            "type": "string"
                        },
                        "exporterPortName": {
                            "type": "string"
                        },
                        "exporterServiceName": {
                            "type": "string"
                        },
                        "usageMetrics": {
                            "type": "boolean"
                        }
                    }
                },
                "logLevel": {
                    "type": "string"
                },
                "nodeAddressTypes": {
                    "type": "string"
                },
                "reportHTTPProxy": {
                    "type": "string"
                },
                "secret": {
                    "type": "object",
                    "properties": {
                        "key": {
                            "type": "string"
                        },
                        "name": {
                            "type": "string"
                        }
                    }
                },
                "token": {
                    "type": "string"
                },
                "useDeployment": {
                    "type": "boolean"
                },
                "volumes": {
                    "type": "array"
                },
                "volumesMounts": {
                    "type": "array"
                },
                "extraEnv": {
                    "type": "array"
                },
                "pollingInterval": {
                    "type": "integer"
                },
                "listLimit": {
                    "type": "integer"
                },
                "networkCost": {
                    "type": "object",
                    "properties": {
                        "enabled": {
                            "type": "boolean"
                        },
                        "port": {
                            "type": "integer"
                        },
                        "source": {
                            "type": "string",
                            "enum": ["conntrack", "ebpf"]
                        },
                        "cgroupRoot": {
                            "type": "string"
                        },
                        "ebpfDebug": {
                            "type": "boolean"
                        },
                        "image": {
                            "type": "object",
                            "properties": {
                                "repository": {
                                    "type": "string"
                                },
                                "tag": {
                                    "type": "string"
                                }
                            }
                        },
                        "subnets": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "cidr": {
                                        "type": "string"
                                    },
                                    "zone": {
                                        "type": "string"
                                    },
                                    "region": {
                                        "type": "string"
                                    }
                                },
                                "required": ["cidr"]
                            }
                        },
                        "overrides": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "cidr": {
                                        "type": "string"
                                    },
                                    "bucket": {
                                        "type": "string"
                                    }
                                },
                                "required": ["cidr", "bucket"]
                            }
                        },
                        "existingConfigMap": {
                            "type": "string"
                        },
                        "resources": {
                            "type": "object"
                        },
                        "tolerations": {
                            "type": "array"
                        },
                        "nodeSelector": {
                            "type": "object"
                        },
                        "affinity": {
                            "type": "object"
                        }
                    }
                }
            }
        },
        "appLabels": {
            "type": "object"
        },
        "clusterRole": {
            "type": "object",
            "properties": {
                "annotations": {
                    "type": "object"
                }
            }
        },
        "clusterRoleBinding": {
            "type": "object",
            "properties": {
                "annotations": {
                    "type": "object"
                }
            }
        },
        "fullnameOverride": {
            "type": "string"
        },
        "image": {
            "type": "object",
            "properties": {
                "pullPolicy": {
                    "type": "string"
                },
                "repository": {
                    "type": "string"
                },
                "tag": {
                    "type": "string"
                }
            }
        },
        "imagePullSecrets": {
            "type": "array"
        },
        "nameOverride": {
            "type": "string"
        },
        "nodeSelector": {
            "type": "object"
        },
        "persist": {
            "type": ["object", "null"],
            "properties": {
                "mountPath": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "size": {
                    "type": "string"
                },
                "storageClassName": {
                    "type": "string"
                }
            }
        },
        "persistS3": {
            "type": "object",
            "properties": {
                "bucket": {
                    "type": "string"
                },
                "prefix": {
                    "type": "string"
                }
            }
        },
        "podAnnotations": {
            "type": "object"
        },
        "podLabels": {
            "type": "object"
        },
        "resources": {
            "type": "object",
            "properties": {
                "limits": {
                    "type": "object",
                    "properties": {
                        "cpu": {
                            "type": "string"
                        },
                        "memory": {
                            "type": "string"
                        }
                    }
                },
                "requests": {
                    "type": "object",
                    "properties": {
                        "cpu": {
                            "type": "string"
                        },
                        "memory": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "securityContext": {
            "type": "object"
        },
        "podSecurityContext": {
            "type": "object"
        },
        "service": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string"
                },
                "port": {
                    "type": "integer"
                },
                "type": {
                    "type": "string"
                }
            }
        },
        "serviceAccount": {
            "type": "object",
            "properties": {
                "annotations": {
                    "type": "object"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "tolerations": {
            "type": "array"
        },
        "podDisruptionBudget": {
            "type": "object",
            "properties": {
                "maxUnavailable": {
                    "type": ["integer", "string"]
                },
                "minAvailable": {
                    "type": ["integer", "string"]
                }
            }
        }

    }
}
